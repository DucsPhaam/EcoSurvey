{
  "name": "ecosurvey-backend",
  "version": "1.0.0",
  "description": "EcoSurvey Backend API - Node.js + Express + Sequelize + MySQL",
  "main": "src/server.js",
  "scripts": {
    "start": "node --dns-result-order=ipv4first src/server.js",
    "dev": "nodemon --exec 'node --dns-result-order=ipv4first' src/server.js",
    "lint": "eslint src/**/*.js",
    "test": "jest --forceExit",
    "test:watch": "jest --watch --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "db:migrate": "sequelize-cli db:migrate",
    "db:seed": "sequelize-cli db:seed:all",
    "db:reset": "sequelize-cli db:drop && sequelize-cli db:create && sequelize-cli db:migrate && sequelize-cli db:seed:all"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cloudinary": "^2.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-validator": "^7.2.0",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.11.3",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.15",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.15.0",
    "sequelize": "^6.37.3",
    "socket.io": "^4.8.3",
    "uuid": "^10.0.0",
    "winston": "^3.14.2",
    "xss": "^1.0.15"
  },
  "devDependencies": {
    "eslint": "^9.11.1",
    "jest": "^30.4.2",
    "nodemon": "^3.1.7",
    "sequelize-cli": "^6.6.5",
    "sequelize-mock": "^0.10.2",
    "sqlite3": "^6.0.1",
    "supertest": "^7.2.2"
  }
}
