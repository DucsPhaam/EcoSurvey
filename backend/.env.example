# ─── Database ────────────────────────────────────
DB_HOST=localhost
DB_PORT=3307
DB_NAME=ecosurvey
DB_USER=root
DB_PASSWORD=12345678
MYSQL_ROOT_PASSWORD=12345678

# ─── JWT ─────────────────────────────────────────
JWT_SECRET=change_me_in_production_very_long_random_secret_min_32_chars
JWT_REFRESH_SECRET=another_very_long_random_refresh_secret_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Server ───────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:3000

# ─── File Uploads (Cloudinary) ────────────────────
MAX_FILE_SIZE_MB=5
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Google OAuth ────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── AI (OpenRouter) ─────────────────────────────────
# Leave empty to use mock responses during development
OPENROUTER_API_KEY=
# ─── Email (SMTP) ────────────────────────────────
# Leave empty to log emails to console during development
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=EcoSurvey <noreply@ecosurvey.edu.vn>
